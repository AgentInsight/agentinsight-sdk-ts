{
  "name": "agentinsight",
  "version": "0.1.0",
  "description": "AgentInsight JavaScript / TypeScript SDK",
  "author": "AgentInsight",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --build",
    "check:format": "prettier --check \"**/*.{ts,js,json,md}\" --log-level error --experimental-cli",
    "check:lint": "eslint \"packages/*/src/**/*.ts\" --quiet",
    "check:type": "tsc -b --noEmit",
    "precommit:check": "turbo run check:lint check:type check:format --continue=never",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "pnpm run build && vitest run --project=integration",
    "test:integration:watch": "pnpm run build && vitest --project=integration",
    "lint": "eslint \"packages/*/src/**/*.ts\" --quiet",
    "lint:fix": "eslint \"packages/*/src/**/*.ts\" --fix",
    "format": "prettier --write \"**/*.{ts,js,json,md}\" --experimental-cli",
    "format:check": "prettier --check \"**/*.{ts,js,json,md}\" --log-level error --experimental-cli",
    "typecheck": "tsc -b --noEmit",
    "ci": "pnpm build && pnpm test && pnpm lint && pnpm typecheck && pnpm format:check",
    "clean": "tsc --build --clean",
    "nuke": "pnpm clean && rm -rf node_modules && rm -rf packages/*/node_modules && pnpm install",
    "prepare": "husky"
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^2",
    "@ai-sdk/openai": "^2",
    "@eslint/js": "^9.32.0",
    "@langchain/core": "^1.1.24",
    "@langchain/langgraph": "^1.1.4",
    "@langchain/openai": "^1.2.7",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/core": "^2.0.1",
    "@opentelemetry/resources": "^2.0.1",
    "@opentelemetry/sdk-node": "^0.205.0",
    "@opentelemetry/sdk-trace-base": "^2.0.1",
    "@opentelemetry/sdk-trace-node": "^2.0.1",
    "@opentelemetry/semantic-conventions": "^1.34.0",
    "@types/mustache": "^4.2.6",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "ai": "^5",
    "dotenv": "^17.2.0",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "happy-dom": "^20.8.9",
    "husky": "^9.1.7",
    "mustache": "^4.2.0",
    "nanoid": "^5.1.5",
    "openai": "^5.0.0",
    "prettier": "^3.6.2",
    "tsup": "^8.5.0",
    "turbo": "^2.8.13",
    "typescript": "^5.3.0",
    "vitest": "^3.2.4",
    "zod": "^3.25.76"
  },
  "engines": {
    "node": ">=20"
  },
  "resolutions": {
    "ml-spectra-processing": "14.14.0"
  },
  "packageManager": "pnpm@10.33.0",
  "keywords": [
    "agentinsight",
    "observability",
    "opentelemetry",
    "tracing",
    "ai",
    "llm",
    "sdk"
  ],
  "homepage": "https://agent.goldebridge.com",
  "bugs": {
    "url": "https://github.com/AgentInsightSDK/agentinsight-js/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AgentInsightSDK/agentinsight-js"
  }
}
