# AgentInsight server for e2e tests / AgentInsight 服务器（用于 E2E 测试）
AGENTINSIGHT_BASE_URL="http://localhost:3000"
AGENTINSIGHT_PUBLIC_KEY="pk-ai-YOUR_PUBLIC_KEY"
AGENTINSIGHT_SECRET_KEY="sk-ai-YOUR_SECRET_KEY"

# OpenAI API key for e2e tests / OpenAI API 密钥（用于 E2E 测试）
OPENAI_API_KEY=

# Min log level / 最低日志级别
AGENTINSIGHT_LOG_LEVEL=INFO
