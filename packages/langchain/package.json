{
  "name": "@agentinsight-sdk/langchain",
  "version": "0.1.2",
  "description": "AgentInsight integration for LangChain",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "clean": "rm -rf dist"
  },
  "author": "AgentInsight",
  "license": "MIT",
  "keywords": [
    "agentinsight",
    "observability",
    "langchain",
    "tracing",
    "ai",
    "llm",
    "callback"
  ],
  "homepage": "https://agentinsight.goldebridge.com/platform",
  "bugs": {
    "url": "https://github.com/agentinsight/agentinsight-sdk-ts/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/agentinsight/agentinsight-sdk-ts.git",
    "directory": "packages/langchain"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@agentinsight-sdk/core": "workspace:^",
    "@agentinsight-sdk/tracing": "workspace:^"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.3.8",
    "@opentelemetry/api": "^1.9.0"
  }
}
